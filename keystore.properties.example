# Release signing credentials — TEMPLATE.
#
# Copy this file to `keystore.properties` (which is git-ignored) and fill in your own values.
# When present, release builds (`./gradlew assembleRelease` / `bundleRelease`) are signed
# automatically. When absent, release builds are left unsigned (debug builds are unaffected).
#
# Generate a keystore once with Android Studio (Build > Generate Signed Bundle / APK >
# Create new...) or the command line:
#   keytool -genkey -v -keystore keystore/release.jks -keyalg RSA -keysize 2048 \
#           -validity 10000 -alias music-player
#
# NEVER commit `keystore.properties` or the `.jks` file. Back up the keystore + passwords
# safely — the SAME key is required for every future Play Store update.

# Path to the keystore, relative to the project root.
storeFile=keystore/release.jks
storePassword=CHANGEME
keyAlias=music-player
keyPassword=CHANGEME
